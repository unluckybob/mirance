<Window x:Class="Mirance.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MIRANCE - iPhone USB Screen Mirroring" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#0F3460" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📱" FontSize="28" VerticalAlignment="Center"/>
                    <TextBlock Text="MIRANCE" FontSize="28" FontWeight="Bold" Foreground="#E94560" 
                               VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <TextBlock Text="iPhone USB Mirroring" FontSize="14" 
                               Foreground="#A0A0A0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="v1.0" Foreground="#666" VerticalAlignment="Center"/>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel - Device List -->
            <Border Grid.Column="0" Background="#16213E" CornerRadius="10" Padding="15" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Connected iPhone" FontSize="16" FontWeight="SemiBold" 
                               Foreground="#E94560" Margin="0,0,0,15"/>
                    
                    <ListBox x:Name="DeviceList" Grid.Row="1" Background="Transparent" 
                             BorderThickness="0" SelectionChanged="DeviceList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A2E" CornerRadius="5" Padding="10" Margin="0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📱" FontSize="16" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding}" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <Button x:Name="RefreshButton" Grid.Row="2" Content="▶ Start Mirroring" 
                            Background="#E94560" Foreground="White" Padding="15,10" 
                            Margin="0,15,0,0" Click="StartMirroringButton_Click"/>
                </Grid>
            </Border>
            
            <!-- Right Panel - Video Display -->
            <Border Grid.Column="1" Background="#0F0F0F" CornerRadius="10">
                <Grid>
                    <TextBlock x:Name="Placeholder" 
                               Text="🔌 Connect your iPhone via USB&#x0a;and click 'Start Mirroring'"
                               Foreground="#444" FontSize="20" TextAlignment="Center"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image x:Name="VideoDisplay" Stretch="Uniform" Margin="5"/>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#0F3460" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="#A0A0A0" 
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="ConnectionStatus" Grid.Column="1" Text="● Disconnected" 
                           Foreground="#FF4444" VerticalAlignment="Center" Margin="20,0"/>
                <TextBlock x:Name="FPSCounter" Grid.Column="2" Text="FPS: 0" 
                           Foreground="#888" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
