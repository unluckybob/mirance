<Window x:Class="Mirance.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MIRANCE - iPhone USB Screen Mirroring" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1E88E5" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MIRANCE" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text=" - iPhone USB Screen Mirroring" FontSize="14" 
                           Foreground="White" VerticalAlignment="Bottom" Margin="10,0,0,2"/>
            </StackPanel>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Device List -->
            <Border Grid.Column="0" Background="#F5F5F5" CornerRadius="5" Padding="10" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Connected Devices" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <ListBox x:Name="DeviceList" SelectionChanged="DeviceList_SelectionChanged">
                        <ListBoxItem Content="No devices found" IsEnabled="False"/>
                    </ListBox>
                    <Button x:Name="RefreshButton" Content="Refresh" Margin="0,10,0,0" 
                            Click="RefreshButton_Click"/>
                </StackPanel>
            </Border>
            
            <!-- Video Display -->
            <Border Grid.Column="1" Background="Black" CornerRadius="5">
                <Grid>
                    <TextBlock x:Name="Placeholder" Text="Connect an iPhone to start mirroring"
                               Foreground="Gray" FontSize="18" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image x:Name="VideoDisplay" Stretch="Uniform"/>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#E0E0E0" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Ready" VerticalAlignment="Center"/>
                <TextBlock x:Name="FPSCounter" Text="FPS: 0" Grid.Column="1" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
